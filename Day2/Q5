#include <stdio.h>

int main(){
    int sum, n, remainder, result=0;
    printf("enter the number to find sum of digit of the number ");
    scanf("%d", &n);

    while(n>0){
        remainder=n%10;
        result=result+remainder;
        n=n/10;
    }

    printf("the sum of the digit of given number is :%d", result);


    return 0;
}
